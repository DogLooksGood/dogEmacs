# -*- mode: snippet -*-
# name: shadow-cljs
# key: shadow-cljs-browser
# --
{:deps   ${1:{:aliases [${2::cljs}]}}
 :builds {:app {:target        :browser
                :output-dir    "resources/public/js"
                :modules
                {:main   {:entries    [${3:entry-namespace}]
                          :init-fn    $3/init}}

                :devtools
                {:http-port   4000
                 :http-root   "resources/public"
                 :after-load  $3/after-load}}}}