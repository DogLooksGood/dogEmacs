# -*- mode: snippet -*-
# name: shadow-cljs
# key: shadow-cljs-browser
# --
{:deps   ${1:{:aliases [${2::cljs}]}}
 :dev-http {4000 "classpath:public"}
 :builds {:app {:target        :browser
                :output-dir    "resources/public/js"
                :modules
                {:main   {:init-fn    $3/init}}
                :devtools
                {:after-load  $3/after-load
                 :preloads [com.fulcrologic.fulcro.inspect.preload]}}}}